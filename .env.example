# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://postly_user:postly_pass@localhost:5433/postly_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (AES-256) — must be exactly 32 chars
ENCRYPTION_KEY=your_32_char_encryption_key_here_

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://spruce-unrest-purgatory.ngrok-free.dev/webhook/telegram

# OpenAI (platform fallback key)
OPENAI_API_KEY=sk-...

# Anthropic (platform fallback key)
ANTHROPIC_API_KEY=sk-ant-...
