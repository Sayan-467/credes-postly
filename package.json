    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "grammy": "^1.21.1",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^4.26.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prisma": "^7.8.0",
    "supertest": "^6.3.4"
